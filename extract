#!/usr/bin/env python3
import sys
import json

def main():
    for line in sys.stdin:
        if not line.strip():
            continue
        try:
            event = json.loads(line)
            
            if event.get("type") == "token" and event.get("source") == "assistant":
                sys.stdout.write(event["payload"]["text"])
                sys.stdout.flush()
                
            elif event.get("type") == "message_complete":
                sys.stdout.write("\n")
                sys.stdout.flush()
                
            # Fallback in case it intercepts a non-streaming complete message
            elif event.get("type") == "message" and event.get("source") == "assistant":
                print(event["payload"]["text"])
                
        except Exception:
            pass

if __name__ == "__main__":
    main()