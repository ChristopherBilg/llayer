#!/usr/bin/env python3
import sys
import json
import urllib.request

OLLAMA_URL = "http://localhost:11434/api/chat"
MODEL_NAME = "llama3.2:1b"

def stream_llm(messages_array):
    api_payload = {
        "model": MODEL_NAME,
        "messages": messages_array,
        "stream": True
    }
    
    req = urllib.request.Request(
        OLLAMA_URL,
        data=json.dumps(api_payload).encode('utf-8'),
        headers={'Content-Type': 'application/json'}
    )
    
    try:
        with urllib.request.urlopen(req) as response:
            for line in response:
                if not line.strip():
                    continue
                
                chunk = json.loads(line.decode('utf-8'))
                token = chunk.get("message", {}).get("content", "")
                
                if token:
                    token_event = {
                        "type": "token",
                        "source": "assistant",
                        "payload": {"text": token}
                    }
                    print(json.dumps(token_event))
                    sys.stdout.flush() 
                    
                if chunk.get("done", False):
                    completion_event = {
                        "type": "message_complete",
                        "source": "system",
                        "payload": {}
                    }
                    print(json.dumps(completion_event))
                    sys.stdout.flush()

    except Exception as e:
        sys.stderr.write(f"Streaming Error: {e}\n")

def main():
    input_data = sys.stdin.read().strip()
    if not input_data:
        return
        
    try:
        # Expects the complete array outputted by llm-context
        messages = json.loads(input_data)
        if isinstance(messages, list):
            stream_llm(messages)
        else:
            sys.stderr.write("Pipeline Error: llm-invoke expected a JSON array of messages.\n")
    except Exception as e:
        sys.stderr.write(f"Pipeline Input Error: {e}\n")

if __name__ == "__main__":
    main()
