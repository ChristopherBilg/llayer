#!/usr/bin/env python3
import sys
import json

def main():
    reconstructed_events = []
    current_token_buffer = ""
    
    for line in sys.stdin:
        if not line.strip():
            continue
        try:
            event = json.loads(line)
            
            if event.get("type") in ["message", "tool_call", "tool_result"]:
                reconstructed_events.append(event)
                
            elif event.get("type") == "token" and event.get("source") == "assistant":
                current_token_buffer += event.get("payload", {}).get("text", "")
                
            elif event.get("type") == "message_complete":
                if current_token_buffer:
                    reconstructed_events.append({
                        "type": "message",
                        "source": "assistant",
                        "payload": {"text": current_token_buffer}
                    })
                    current_token_buffer = "" 
                    
        except Exception as e:
            sys.stderr.write(f"Context Parser Error: {e}\n")

    if current_token_buffer:
         reconstructed_events.append({
             "type": "message",
             "source": "assistant",
             "payload": {"text": current_token_buffer}
         })

    if not reconstructed_events:
        return

    system_events = [e for e in reconstructed_events if e.get("source") == "system" and e.get("type") == "message"]
    recent_events = [e for e in reconstructed_events if e.get("source") != "system"][-10:]
    
    messages = []
    for e in (system_events + recent_events):
        role = e["source"]
        if role not in ["system", "user", "assistant"]:
            role = "user" 
            
        messages.append({
            "role": role,
            "content": e["payload"].get("text", str(e["payload"]))
        })

    print(json.dumps(messages))

if __name__ == "__main__":
    main()